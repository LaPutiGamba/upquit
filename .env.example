BACKEND_PORT=8080
LOG_LEVEL=info

POSTGRES_USER=upquit_admin
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_DB=upquit
# For local development, you will have to set the DATABASE_URL with the actual credentials. For example:
#DATABASE_URL=postgresql://upquit_admin:secure_password_change_me@localhost:5432/upquit
# For docker compose, you can use the following DATABASE_URL:
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

NODE_ENV=development

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RESEND_API_KEY=